{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(git status*)",
      "Bash(git -C * status*)",
      "Bash(git diff*)",
      "Bash(git -C * diff*)",
      "Bash(git log*)",
      "Bash(git -C * log*)",
      "Bash(git add*)",
      "Bash(git -C * add*)",
      "Bash(git commit*)",
      "Bash(git -C * commit*)",
      "Bash(git branch*)",
      "Bash(git -C * branch*)",
      "Bash(git checkout*)",
      "Bash(git -C * checkout*)",
      "Bash(git switch*)",
      "Bash(git -C * switch*)",
      "Bash(git merge*)",
      "Bash(git -C * merge*)",
      "Bash(git rebase*)",
      "Bash(git -C * rebase*)",
      "Bash(git stash*)",
      "Bash(git -C * stash*)",
      "Bash(git tag*)",
      "Bash(git -C * tag*)",
      "Bash(git fetch*)",
      "Bash(git -C * fetch*)",
      "Bash(git pull*)",
      "Bash(git -C * pull*)",
      "Bash(git reset*)",
      "Bash(git -C * reset*)",
      "Bash(git cherry-pick*)",
      "Bash(git -C * cherry-pick*)",
      "Bash(git show*)",
      "Bash(git -C * show*)",
      "Bash(git blame*)",
      "Bash(git -C * blame*)",
      "Bash(git reflog*)",
      "Bash(git -C * reflog*)",
      "Bash(git rev-parse*)",
      "Bash(git -C * rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(git -C * rev-list*)",
      "Bash(git symbolic-ref*)",
      "Bash(git -C * symbolic-ref*)",
      "Bash(git worktree*)",
      "Bash(git -C * worktree*)",
      "Bash(git clean*)",
      "Bash(git -C * clean*)",
      "Bash(git rm*)",
      "Bash(git -C * rm*)",
      "Bash(git mv*)",
      "Bash(git -C * mv*)",
      "Bash(git restore*)",
      "Bash(git -C * restore*)",
      "Bash(git config*)",
      "Bash(git -C * config*)",
      "Bash(git remote*)",
      "Bash(git -C * remote*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git -C * push*)"
    ]
  },
  "model": "claude-opus-4-6[1M]",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "learning-output-style@claude-code-plugins": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "verbose": true,
  "agentPushNotifEnabled": true
}
