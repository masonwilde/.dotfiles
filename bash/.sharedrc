source "$HOME/.pathrc"

# Detect shell
if [ -n "$ZSH_VERSION" ]; then
	_shell="zsh"
elif [ -n "$BASH_VERSION" ]; then
	_shell="bash"
fi

source "$HOME/.aliases"
source "$HOME/.functions"

# Work overrides or dev tooling
if [ -f "$HOME/.workrc" ]; then
	source "$HOME/.workrc"
else
	eval "$(direnv hook $_shell)"
	eval "$(pyenv init -)"
fi

# Vi mode
if [ "$_shell" = "zsh" ]; then
	bindkey -v
else
	set -o vi
fi

eval "$(zoxide init $_shell)"

if command -v wt >/dev/null 2>&1; then
	eval "$(command wt config shell init $_shell)"
fi

unset _shell
