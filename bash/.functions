# Git Helpers
parse_git_branch() {
     git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/(\1)/'
}

venv() {
    local dir_name=$(basename "$PWD")

    # Check if .envrc already exists
    if [ -f .envrc ]; then
        echo "Error: .envrc already exists" >&2
        return 1
    fi

    # Create venv using uv with all passed arguments
    if ! uv venv; then
        echo "Error: Failed to create venv" >&2
        return 1
    fi

    # Create .envrc
    echo "layout python" >> .envrc

    # Allow direnv to immediately activate the virtual environment
    direnv allow
}

git-pr() {
    if [ -z "$1" ]; then
        echo "Usage: git-pr <PR_NUMBER>"
        return 1
    fi

    # Fetch the PR branch
    git fetch origin pull/$1/head:pr/$1

    # Get the base branch using GitHub CLI (if available)
    if command -v gh &> /dev/null; then
        base_branch=$(gh pr view $1 --json baseRefName -q .baseRefName 2>/dev/null)
        if [ -n "$base_branch" ]; then
            echo "Base branch: $base_branch"
            git fetch origin "$base_branch:$base_branch"
        fi
    fi

    git checkout pr/$1
}
